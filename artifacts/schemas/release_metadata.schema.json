{
  "schema_id": "release_metadata",
  "version": "v1",
  "artifact_name": "release_metadata.json",
  "responsibility": "Machine-readable, auditable metadata for an approved release.",
  "owner_roles": ["agent_release_manager"],
  "allowed_readers": ["human", "agent_orchestrator", "agent_reflector"],
  "write_policy": {
    "mutability": "versioned",
    "overwrite_allowed": false
  },
  "required_fields": {
    "release_id": "<stable-string-id>",
    "created_at": "<iso-8601>",
    "inputs": {
      "review_result_ref": "<string>",
      "test_report_run_id": "<string>",
      "implementation_plan_id": "<string>"
    },
    "artifacts": [
      {
        "name": "<string>",
        "ref": "<string>",
        "hash": "<optional-string>"
      }
    ],
    "environment": {
      "os": "<string>",
      "tool_versions": {
        "<tool>": "<version>"
      }
    }
  },
  "determinism_requirements": {
    "release_id_stable": true,
    "inputs_must_be_explicit": true
  }
}
